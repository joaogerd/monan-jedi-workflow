# JACI site configuration for MONAN-JEDI-WORKFLOW.
# Copy to site.env and edit values for your account and installation.

export MONAN_SITE="jaci"
export MONAN_PROJECT="MONAN"
export MONAN_QUEUE="normal"
export MONAN_WALLTIME_SMOKE="00:10:00"

export MONAN_WORK_ROOT="/work/${USER}/monan-jedi-workflow"
export MONAN_SCRATCH="/scratch/${USER}/monan-jedi-workflow"
export MONAN_DATA_ROOT="${MONAN_WORK_ROOT}/data"
export MONAN_EXPERIMENT_ROOT="${MONAN_SCRATCH}/experiments"

export MPAS_BUNDLE_BUILD="/path/to/mpas-bundle/build"
export MPAS_ATMOSPHERE_EXE="${MPAS_BUNDLE_BUILD}/bin/mpas_atmosphere"
export MPASJEDI_VARIATIONAL_EXE="${MPAS_BUNDLE_BUILD}/bin/mpasjedi_variational.x"
export MPASJEDI_HOFX_EXE="${MPAS_BUNDLE_BUILD}/bin/mpasjedi_hofx3d.x"

export MPI_LAUNCHER="mpiexec"
export CYLC_PLATFORM="pbs_cluster"
