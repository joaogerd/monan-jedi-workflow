# JACI site configuration for MONAN-JEDI-WORKFLOW.
#
# Copy this file to:
#
#   configs/sites/jaci/site.env
#
# and edit values for your JACI account, project allocation, filesystem layout,
# MPAS-JEDI installation and spack-stack-inpe runtime environment.

export MONAN_SITE="jaci"
export MONAN_PROJECT="MONAN"
export MONAN_QUEUE="pesqmini"
export MONAN_WALLTIME_SMOKE="00:10:00"
export MONAN_WALLTIME_3DVAR="00:30:00"

export MONAN_JACI_WORKSPACE="/p/projetos/monan_das/${USER}"
export MONAN_WORKFLOW_ROOT="${MONAN_JACI_WORKSPACE}/projects/monan-jedi-workflow"
export MONAN_WORK_ROOT="${MONAN_WORKFLOW_ROOT}"
export MONAN_SCRATCH="${MONAN_JACI_WORKSPACE}/scratch/monan-jedi-workflow"
export MONAN_DATA_ROOT="${MONAN_WORK_ROOT}/data"
export MONAN_EXTERNAL_DATA_ROOT="${MONAN_JACI_WORKSPACE}/external-inputs/3dvar_fgat"
export MONAN_EXPERIMENT_ROOT="${MONAN_SCRATCH}/experiments"

# Load the same spack-stack-inpe runtime environment used to compile the
# selected MONAN-JEDI/MPAS-JEDI executable. Keep these values site-configurable
# so a new stack installation can be selected without changing workflow code.
export MONAN_LOAD_STACK="true"
export STACK_ROOT="/path/to/spack-stack"
export STACK_ENV_NAME="jaci-mpas-jedi-gcc12-craympich"
export STACK_MODULE_ROOT="${STACK_ROOT}/envs/${STACK_ENV_NAME}/modules"
export STACK_ENV_MODULE="cray-mpich/8.1.31/none/none/jedi-mpas-env/1.0.0"
export STACK_SITE_SETUP="${STACK_ROOT}/configs/sites/tier2/jaci/setup.sh"

# Load Anaconda after the stack runtime, because the stack setup may reset modules.
export MONAN_LOAD_ANACONDA="true"

export MPAS_BUNDLE_BUILD="/path/to/mpas-bundle/build"
export MPAS_ATMOSPHERE_EXE="${MPAS_BUNDLE_BUILD}/bin/mpas_atmosphere"
export MPASJEDI_VARIATIONAL_EXE="${MPAS_BUNDLE_BUILD}/bin/mpasjedi_variational.x"
export MPASJEDI_HOFX_EXE="${MPAS_BUNDLE_BUILD}/bin/mpasjedi_hofx3d.x"

# JACI Cray/PALS jobs should use mpirun. The task-count flag remains configurable
# for portability to other launchers such as mpiexec or srun.
export MPI_LAUNCHER="mpirun"
export MPI_TASKS_FLAG="-np"
export CYLC_PLATFORM="pbs_cluster"

export MONAN_DEFAULT_CYCLE="2018041500"
export MONAN_DEFAULT_MPI_TASKS="64"
export MONAN_DEFAULT_NODES="1"
export MONAN_DEFAULT_NCPUS="64"
export MONAN_DEFAULT_MPIPROCS="64"

export MONAN_BACKGROUND_ROOT="${MONAN_DATA_ROOT}/background"
export MONAN_IODA_ROOT="${MONAN_DATA_ROOT}/observations/ioda"
export MONAN_COVARIANCE_ROOT="${MONAN_DATA_ROOT}/covariance"
export MONAN_GRAPH_ROOT="${MONAN_DATA_ROOT}/graph"
export MONAN_STATIC_ROOT="${MONAN_DATA_ROOT}/static"

export MONAN_JACI_MODULES_FILE="${MONAN_WORKFLOW_ROOT}/configs/sites/jaci/modules.sh"
