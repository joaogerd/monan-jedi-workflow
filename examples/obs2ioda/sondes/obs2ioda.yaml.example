# Copie este arquivo para obs2ioda.yaml e preencha somente os valores locais.
#
# O wrapper de conversão é intencional: a interface do conversor de sondagem
# precisa ser a que foi validada no JACI para a versão publicada do Obs2IODA.
# O pipeline registra a chamada efetiva, entradas, saídas, logs e inspeção IODA.

obs2ioda:
  variables:
    # Executável publicado pelo bundle MONAN-JEDI.
    obs2ioda_executable: /p/projetos/monan_das/USUARIO/builds/monan-jedi/bin/obs2ioda_v3

    # Inspecionador NetCDF/HDF5 disponível no ambiente de execução.
    ncdump_executable: ncdump

    # Wrapper local que encapsula a chamada comprovada para sondagens.
    sonde_converter: /p/projetos/monan_das/USUARIO/projects/monan-jedi-workflow/scripts/obs2ioda/convert_sondes.sh

    # Raiz com arquivos de entrada por ciclo; ajustar ao catálogo adotado.
    sonde_input_root: /p/projetos/monan_das/USUARIO/data/observations/sondes

    # Área de produtos versionada para este caso de conversão.
    output_root: /p/projetos/monan_das/USUARIO/work/obs2ioda-sondes

  work_dir: "{output_root}/{cycle_id}"

  # Probes são opcionais. Só mantenha comandos que funcionem na instalação local.
  probes:
    - name: obs2ioda-interface
      argv: ["{obs2ioda_executable}", "--help"]
      required_output_markers: []
      timeout_seconds: 30

  inspection:
    argv: ["{ncdump_executable}", -h, "{output}"]
    required_header_markers:
      - MetaData
      - ObsValue
      - ObsError
      - PreQC
    timeout_seconds: 60

  # SHA-256 é útil para rastreabilidade, mas pode ser caro para grandes volumes.
  provenance:
    sha256: false

  converters:
    - name: sondes
      inputs:
        - "{sonde_input_root}/{cycle_id}.bufr"
      outputs:
        - "{work_dir}/sondes.nc4"
      timeout_seconds: 900
      argv:
        - "{sonde_converter}"
        - --input
        - "{sonde_input_root}/{cycle_id}.bufr"
        - --output
        - "{work_dir}/sondes.nc4"
      validation:
        required_header_markers:
          - MetaData
          - ObsValue
          - ObsError
          - PreQC
