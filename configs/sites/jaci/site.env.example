# JACI site configuration for MONAN-JEDI-WORKFLOW.
#
# Copy this file to:
#
#   configs/sites/jaci/site.env
#
# and edit values for your JACI account, project allocation, filesystem layout and
# MPAS-JEDI installation.
#
# This file is sourced by scripts/env/load_jaci_env.sh and by rendered PBS jobs.

# -----------------------------------------------------------------------------
# Site identity and PBS settings
# -----------------------------------------------------------------------------

export MONAN_SITE="jaci"
export MONAN_PROJECT="MONAN"        # TODO: replace with real PBS project/account if needed
export MONAN_QUEUE="pesqmini"       # Observed enabled small validation queue on JACI
export MONAN_WALLTIME_SMOKE="00:10:00"
export MONAN_WALLTIME_3DVAR="00:30:00"

# -----------------------------------------------------------------------------
# Repository, work, scratch and data roots
# -----------------------------------------------------------------------------

# Observed JACI project workspace used during validation:
#   /p/projetos/monan_das/joao.gerd
export MONAN_JACI_WORKSPACE="/p/projetos/monan_das/${USER}"

# Absolute path to the MONAN-JEDI-WORKFLOW checkout on JACI.
export MONAN_WORKFLOW_ROOT="${MONAN_JACI_WORKSPACE}/projects/monan-jedi-workflow"

# Persistent work area for builds, small static files and repository-adjacent data.
export MONAN_WORK_ROOT="${MONAN_JACI_WORKSPACE}/projects/monan-jedi-workflow"

# Scratch/runtime area for experiment directories, logs and large temporary files.
# Adjust if JACI policy requires a different high-performance scratch path.
export MONAN_SCRATCH="${MONAN_JACI_WORKSPACE}/scratch/monan-jedi-workflow"

# Root directory for staged/canonical input data used directly by experiments.
export MONAN_DATA_ROOT="${MONAN_WORK_ROOT}/data"

# Root directory where external scientific inputs are collected before staging into
# MONAN_DATA_ROOT. Replace this with the real shared/user input location when available.
export MONAN_EXTERNAL_DATA_ROOT="${MONAN_JACI_WORKSPACE}/external-inputs/3dvar_fgat"

# Root directory for experiment outputs.
export MONAN_EXPERIMENT_ROOT="${MONAN_SCRATCH}/experiments"

# -----------------------------------------------------------------------------
# MPAS/JEDI installation
# -----------------------------------------------------------------------------

# Build or install directory of the selected MPAS-JEDI bundle.
# TODO: replace after the JEDI bundle location is finalized on JACI.
export MPAS_BUNDLE_BUILD="/path/to/mpas-bundle/build"

export MPAS_ATMOSPHERE_EXE="${MPAS_BUNDLE_BUILD}/bin/mpas_atmosphere"
export MPASJEDI_VARIATIONAL_EXE="${MPAS_BUNDLE_BUILD}/bin/mpasjedi_variational.x"
export MPASJEDI_HOFX_EXE="${MPAS_BUNDLE_BUILD}/bin/mpasjedi_hofx3d.x"

# -----------------------------------------------------------------------------
# MPI and scheduler interface
# -----------------------------------------------------------------------------

# On JACI, mpiexec was observed under /opt/pbs/bin/mpiexec after loading the PBS environment.
export MPI_LAUNCHER="mpiexec"

# Cylc platform name. Keep pbs_cluster initially to remain close to upstream MPAS-Workflow.
export CYLC_PLATFORM="pbs_cluster"

# -----------------------------------------------------------------------------
# Experiment defaults used by current smoke configuration
# -----------------------------------------------------------------------------

export MONAN_DEFAULT_CYCLE="2024081500"
export MONAN_DEFAULT_MPI_TASKS="128"
export MONAN_DEFAULT_NODES="1"
export MONAN_DEFAULT_NCPUS="128"
export MONAN_DEFAULT_MPIPROCS="128"

# -----------------------------------------------------------------------------
# Data layout expected by the current 3DVar-FGAT smoke workflow
# -----------------------------------------------------------------------------

export MONAN_BACKGROUND_ROOT="${MONAN_DATA_ROOT}/background"
export MONAN_IODA_ROOT="${MONAN_DATA_ROOT}/observations/ioda"
export MONAN_COVARIANCE_ROOT="${MONAN_DATA_ROOT}/covariance"
export MONAN_GRAPH_ROOT="${MONAN_DATA_ROOT}/graph"
export MONAN_STATIC_ROOT="${MONAN_DATA_ROOT}/static"

# -----------------------------------------------------------------------------
# Module command file
# -----------------------------------------------------------------------------

# This file loads the JACI Anaconda module and runs start_conda.
export MONAN_JACI_MODULES_FILE="${MONAN_WORKFLOW_ROOT}/configs/sites/jaci/modules.sh"
