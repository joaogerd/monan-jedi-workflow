# Perfil PREPBUFR -> IODA que exige somente a coleção de sondagens.
#
# Use este perfil quando a assimilação requer sondagens e o PREPBUFR do ciclo
# realmente contém esse tipo observacional. Para o teste operacional de
# 2026-06-26T00:00:00Z, por exemplo, este perfil deve falhar corretamente:
# aquele PREPBUFR continha somente observações de superfície após o QC.

obs2ioda:
  variables:
    workflow_root: /p/projetos/monan_das/USUARIO/projects/monan-jedi-workflow
    obs2ioda_executable: /p/projetos/monan_das/USUARIO/builds/monan-jedi-mpas/bin/obs2ioda_v3
    prepbufr_runner: "{workflow_root}/scripts/obs2ioda/run_prepbufr.sh"

    # Ajuste para o arquivo PREPBUFR associado ao ciclo escolhido.
    prepbufr_input: /p/caminho/para/prepbufr.bufr
    output_root: /p/projetos/monan_das/USUARIO/work/obs2ioda-sondes

  work_dir: "{output_root}/{cycle_yyyymmddhh}"

  inspection:
    argv: [ncdump, -h, "{output}"]
    required_header_markers:
      - MetaData
      - ObsValue
      - ObsError
      - PreQC
    timeout_seconds: 60

  provenance:
    sha256: false

  converters:
    - name: prepbufr-sondes
      inputs:
        - "{prepbufr_input}"
        - "{prepbufr_runner}"
      outputs:
        - "{work_dir}/sondes_obs_{cycle_yyyymmddhh}.h5"
      timeout_seconds: 900
      argv:
        - bash
        - "{prepbufr_runner}"
        - --executable
        - "{obs2ioda_executable}"
        - --input
        - "{prepbufr_input}"
